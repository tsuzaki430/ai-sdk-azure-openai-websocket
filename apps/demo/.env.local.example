AZURE_API_KEY=your-key
AZURE_RESOURCE_NAME=your-resource-name
AZURE_OPENAI_API_VERSION=v1

# Optional. Use this instead of AZURE_RESOURCE_NAME when you need to provide
# the full Azure OpenAI base URL, e.g. for a regional/proxy endpoint.
# AZURE_OPENAI_BASE_URL=https://your-resource-name.openai.azure.com/openai
